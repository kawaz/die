.DS_Store
.cache/

# Build outputs per-language (each impl writes its binary to <impl>/bin/die).
# Inline comments are not supported in .gitignore — keep these on their own line.
**/bin/
**/dist/
**/target/
**/_build/
**/.zig-cache/
**/zig-cache/
**/zig-out/

# Cargo: also exclude lockfile from binary-crate workspaces? we keep it
# (Cargo.lock is recommended for binary crates).
*.test
*.out

# Per-session temp area for commit message drafts and scratch scripts.
scratchpad/
